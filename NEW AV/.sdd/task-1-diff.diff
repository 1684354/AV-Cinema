+<!DOCTYPE html>
+<html lang="zh-CN">
+<head>
+<meta charset="UTF-8">
+<meta name="viewport" content="width=device-width, initial-scale=1.0">
+<title>AV Cinema · 暗房影集 完整设计</title>
+<style>
+/* ===== 全局 ===== */
+*{margin:0;padding:0;box-sizing:border-box}
+:root{
+  --bg:#1a1513; --bg2:#1f1a17; --bg3:#0f0c0b;
+  --surface:#25201d; --border:#2a2320;
+  --fg:#f0ebe7; --fg2:#cfa899; --fg3:#8a7a72; --fg4:#5a4d45;
+  --accent:#a24a3a; --accent2:#d98e6a; --accent3:#c96a4a;
+  --rose: #e88a7a; --blue: #7ab8e8;
+  --radius:16px; --radius-sm:10px; --radius-xs:8px;
+  --shadow: 0 4px 16px rgba(0,0,0,.3);
+  --transition: all .25s cubic-bezier(.4,0,.2,1);
+}
+body{font-family:'Segoe UI',system-ui,-apple-system,sans-serif;background:var(--bg);color:var(--fg);min-height:100vh;overflow:hidden}
+::-webkit-scrollbar{width:5px;height:5px}
+::-webkit-scrollbar-track{background:transparent}
+::-webkit-scrollbar-thumb{background:var(--border);border-radius:10px}
+::-webkit-scrollbar-thumb:hover{background:var(--fg4)}
+a{color:inherit;text-decoration:none}
+button{cursor:pointer;font-family:inherit}
+
+/* ===== 布局 ===== */
+.app{display:flex;height:100vh}
+
+/* ===== 侧边栏 ===== */
+.sidebar{width:200px;background:var(--bg2);border-right:1px solid var(--border);padding:24px 12px;display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto}
+.sidebar .logo{font-family:Georgia,serif;font-size:22px;color:var(--accent2);padding:8px 12px;margin-bottom:20px;letter-spacing:2px;display:flex;align-items:center;gap:8px}
+.sidebar .logo span{color:var(--fg);font-size:20px}
+.sidebar .grp{font-size:10px;color:var(--fg4);padding:8px 12px 4px;text-transform:uppercase;letter-spacing:1px;margin-top:8px}
+.sidebar .nav-item{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:var(--radius-sm);color:var(--fg3);font-size:13px;transition:var(--transition);margin-bottom:1px;position:relative}
+.sidebar .nav-item:hover{background:var(--surface);color:var(--fg)}
+.sidebar .nav-item.active{background:var(--accent);color:#fff}
+.sidebar .nav-item .ico{font-size:14px;width:20px;text-align:center}
+.sidebar .nav-item .badge{margin-left:auto;font-size:10px;background:var(--surface);padding:2px 8px;border-radius:10px;color:var(--fg3)}
+.sidebar .nav-item.active .badge{background:rgba(255,255,255,.2);color:#fff}
+.sidebar .sep{margin:8px 0;border-top:1px solid var(--border)}
+
+/* ===== 主内容 ===== */
+.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
+
+/* ===== 顶栏 ===== */
+.topbar{display:flex;align-items:center;padding:14px 28px;background:var(--bg);border-bottom:1px solid var(--border);gap:16px;flex-shrink:0}
+.topbar .search-wrap{flex:1;position:relative}
+.topbar .search-wrap input{width:100%;background:var(--bg2);border:1px solid var(--border);border-radius:20px;padding:9px 20px 9px 40px;font-size:13px;color:var(--fg);outline:none;transition:var(--transition)}
+.topbar .search-wrap input::placeholder{color:var(--fg4)}
+.topbar .search-wrap input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(162,74,58,.15)}
+.topbar .search-wrap .search-ico{position:absolute;left:14px;top:50%;transform:translateY(-50%);font-size:14px;color:var(--fg4)}
+.topbar .actions{display:flex;gap:10px}
+.topbar .actions button{padding:7px 16px;border-radius:16px;border:1px solid var(--border);background:var(--bg2);color:var(--fg3);font-size:12px;transition:var(--transition)}
+.topbar .actions button:hover{background:var(--surface);color:var(--fg)}
+
+/* ===== 视图容器 ===== */
+.view{flex:1;overflow-y:auto;padding:24px 28px}
+.view.hidden{display:none}
+
+/* ===== 排序/筛选栏 ===== */
+.sort-bar{display:flex;align-items:center;gap:8px;padding:12px 28px;border-bottom:1px solid var(--border);flex-wrap:wrap;flex-shrink:0;background:var(--bg)}
+.sort-bar .opt{padding:5px 14px;border-radius:14px;font-size:12px;color:var(--fg3);cursor:pointer;transition:var(--transition)}
+.sort-bar .opt:hover{color:var(--fg)}
+.sort-bar .opt.active{background:var(--accent);color:#fff}
+.sort-bar .spacer{flex:1}
+.sort-bar .filter-group{display:flex;gap:6px}
+.sort-bar .filter-group .tag{padding:4px 12px;border-radius:12px;border:1px solid var(--border);font-size:11px;color:var(--fg3);cursor:pointer;transition:var(--transition)}
+.sort-bar .filter-group .tag:hover{background:var(--accent);color:#fff;border-color:var(--accent)}
+.sort-bar .filter-group .tag.active{background:var(--accent);color:#fff;border-color:var(--accent)}
+.view-count{font-size:12px;color:var(--fg4)}
+
+/* ===== 影片卡片网格 ===== */
+.grid{display:grid;grid-template-columns:repeat(5,1fr);gap:18px;padding-bottom:40px}
+.grid .card{background:var(--bg2);border-radius:var(--radius);overflow:hidden;border:1px solid var(--border);transition:var(--transition);cursor:pointer;position:relative}
+.grid .card:hover{transform:translateY(-5px);box-shadow:0 12px 28px rgba(0,0,0,.4),0 0 0 1px rgba(162,74,58,.25)}
+.grid .card .thumb{aspect-ratio:3/4;background:linear-gradient(135deg,var(--surface),var(--border));display:flex;align-items:center;justify-content:center;font-size:32px;position:relative}
+.grid .card .thumb .flags{position:absolute;top:8px;left:8px;display:flex;gap:4px;flex-wrap:wrap}
+.grid .card .thumb .flags span{padding:2px 8px;border-radius:6px;font-size:9px;font-weight:600;background:rgba(0,0,0,.7);color:var(--fg)}
+.grid .card .thumb .flags .accent{background:var(--accent);color:#fff}
+.grid .card .thumb .fav{position:absolute;top:8px;right:8px;font-size:16px;color:rgba(255,255,255,.5);transition:var(--transition)}
+.grid .card .thumb .fav:hover{color:var(--accent2)}
+.grid .card .thumb .fav.active{color:var(--accent2)}
+.grid .card .body{padding:12px 14px 14px}
+.grid .card .body .code{font-size:11px;color:var(--accent2);font-weight:700;letter-spacing:.5px}
+.grid .card .body .title{font-size:13px;margin-top:4px;color:var(--fg);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;line-height:1.4}
+.grid .card .body .meta{font-size:11px;color:var(--fg3);margin-top:6px;display:flex;gap:6px}
+.grid .card .body .tags{display:flex;gap:4px;margin-top:6px;flex-wrap:wrap}
+.grid .card .body .tags span{font-size:9px;padding:2px 7px;border-radius:5px}
+.grid .card .body .tags .r{background:rgba(162,74,58,.2);color:var(--rose)}
+.grid .card .body .tags .b{background:rgba(59,100,140,.2);color:var(--blue)}
+
+/* ===== 右键菜单 ===== */
+.ctx{position:fixed;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:6px;box-shadow:var(--shadow);z-index:100;min-width:160px;display:none}
+.ctx .ctx-item{display:flex;align-items:center;gap:10px;padding:8px 14px;border-radius:6px;font-size:13px;color:var(--fg3);transition:var(--transition)}
+.ctx .ctx-item:hover{background:var(--surface);color:var(--fg)}
+.ctx .ctx-item.danger:hover{background:rgba(162,74,58,.2);color:var(--rose)}
+
+/* ===== 详情页专用 ===== */
+.detail-header{display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-shrink:0}
+.detail-header .back{font-size:16px;color:var(--fg3);cursor:pointer;padding:6px;border-radius:50%;transition:var(--transition)}
+.detail-header .back:hover{background:var(--surface);color:var(--fg)}
+.detail-header .loc{font-size:13px;color:var(--fg4)}
+.detail-header .actions{margin-left:auto;display:flex;gap:10px}
+.detail-header .actions button{padding:8px 20px;border-radius:20px;border:1px solid var(--border);font-size:12px;background:var(--bg2);color:var(--fg3);transition:var(--transition)}
+.detail-header .actions button:hover{background:var(--surface);color:var(--fg)}
+.detail-header .actions .play{background:var(--accent);border-color:var(--accent);color:#fff}
+.detail-header .actions .play:hover{background:var(--accent3)}
+
+.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
+.preview-area{background:var(--bg3);border-radius:var(--radius);height:400px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;border:1px solid var(--border)}
+.preview-area .big{font-size:64px;opacity:.4}
+.preview-area .dots{position:absolute;bottom:16px;display:flex;gap:6px}
+.preview-area .dots span{width:6px;height:6px;border-radius:50%;background:var(--border);cursor:pointer;transition:var(--transition)}
+.preview-area .dots span.active{background:var(--accent2);width:20px;border-radius:3px}
+.filmstrip{display:flex;gap:8px;overflow-x:auto;margin:12px 0 20px;padding-bottom:4px}
+.filmstrip .thumb{flex-shrink:0;width:80px;height:56px;background:var(--surface);border-radius:6px;cursor:pointer;border:2px solid transparent;transition:var(--transition);display:flex;align-items:center;justify-content:center;font-size:18px}
+.filmstrip .thumb:hover{border-color:var(--fg4)}
+.filmstrip .thumb.active{border-color:var(--accent2)}
+
+.info-panel{background:var(--bg2);border-radius:var(--radius);padding:24px;border:1px solid var(--border)}
+.info-panel .code{font-family:Georgia,serif;font-size:20px;color:var(--accent2);display:flex;align-items:center;gap:10px;margin-bottom:6px}
+.info-panel .code .copy{font-size:11px;color:var(--fg4);cursor:pointer;padding:2px 10px;border-radius:8px;background:var(--surface);transition:var(--transition)}
+.info-panel .code .copy:hover{background:var(--border);color:var(--fg)}
+.info-panel .title{font-size:17px;margin-bottom:16px;line-height:1.5}
+.info-fields{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
+.info-fields .f{font-size:12px;color:var(--fg4)}
+.info-fields .f strong{display:block;color:var(--fg);font-weight:400;font-size:13px;margin-top:2px}
+.info-fields .f .link{color:var(--accent2);cursor:pointer;transition:var(--transition)}
+.info-fields .f .link:hover{color:var(--accent)}
+
+.tags-section{margin-bottom:12px}
+.tags-section .gLabel{font-size:10px;color:var(--fg4);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
+.tags-section .tags{display:flex;flex-wrap:wrap;gap:5px}
+.tags-section .tags .t{padding:4px 12px;border-radius:12px;font-size:11px}
+.tags-section .tags .t.red{background:rgba(162,74,58,.2);color:var(--rose);border:1px solid rgba(162,74,58,.25)}
+.tags-section .tags .t.blue{background:rgba(59,100,140,.2);color:var(--blue);border:1px solid rgba(59,100,140,.25)}
+
+.detail-actions{display:flex;gap:8px;margin-top:16px}
+.detail-actions button{padding:8px 18px;border-radius:16px;border:1px solid var(--border);background:var(--surface);color:var(--fg3);font-size:12px;transition:var(--transition)}
+.detail-actions button:hover{background:var(--border);color:var(--fg)}
+
+/* ===== 女优卡片 ===== */
+.actress-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:18px}
+.actress-grid .acard{background:var(--bg2);border-radius:var(--radius);padding:20px;text-align:center;border:1px solid var(--border);transition:var(--transition);cursor:pointer}
+.actress-grid .acard:hover{transform:translateY(-4px);box-shadow:0 8px 20px rgba(0,0,0,.3);border-color:rgba(162,74,58,.3)}
+.actress-grid .acard .avatar{width:72px;height:72px;border-radius:50%;background:var(--surface);margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-size:28px;border:2px solid var(--border);transition:var(--transition)}
+.actress-grid .acard:hover .avatar{border-color:var(--accent2)}
+.actress-grid .acard .aname{font-size:14px;font-weight:600}
+.actress-grid .acard .asub{font-size:11px;color:var(--fg3);margin-top:4px;display:flex;justify-content:center;gap:10px}
+.actress-grid .acard .acount{font-size:11px;color:var(--accent2);margin-top:6px}
+
+/* ===== 收藏页 ===== */
+.tab-bar{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:20px}
+.tab-bar .tab{padding:10px 24px;font-size:13px;color:var(--fg3);cursor:pointer;border-bottom:2px solid transparent;transition:var(--transition)}
+.tab-bar .tab:hover{color:var(--fg)}
+.tab-bar .tab.active{color:var(--accent2);border-bottom-color:var(--accent2)}
+
+/* ===== 标签浏览 ===== */
+.tag-browser{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
+.tag-browser .tgroup{background:var(--bg2);border-radius:var(--radius);padding:18px;border:1px solid var(--border)}
+.tag-browser .tgroup .gtitle{font-family:Georgia,serif;font-size:15px;color:var(--accent2);margin-bottom:10px;display:flex;align-items:center;gap:8px}
+.tag-browser .tgroup .gcount{font-size:10px;color:var(--fg4);font-family:'Segoe UI',sans-serif}
+.tag-browser .tgroup .gtags{display:flex;flex-wrap:wrap;gap:6px}
+.tag-browser .tgroup .gtags span{padding:5px 12px;border-radius:12px;font-size:12px;background:var(--surface);color:var(--fg3);border:1px solid var(--border);cursor:pointer;transition:var(--transition)}
+.tag-browser .tgroup .gtags span:hover{background:var(--accent);color:#fff;border-color:var(--accent)}
+
+/* ===== 网站导航 ===== */
+.website-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
+.website-grid .wsite{background:var(--bg2);border-radius:var(--radius);padding:18px;border:1px solid var(--border);cursor:pointer;transition:var(--transition)}
+.website-grid .wsite:hover{transform:translateY(-3px);border-color:rgba(162,74,58,.3)}
+.website-grid .wsite .wico{font-size:28px;margin-bottom:8px}
+.website-grid .wsite .wname{font-size:14px;font-weight:600}
+.website-grid .wsite .wurl{font-size:11px;color:var(--fg4);margin-top:4px;word-break:break-all}
+.website-grid .wsite .wdesc{font-size:11px;color:var(--fg3);margin-top:4px}
+
+/* ===== 设置 ===== */
+.settings-group{max-width:600px}
+.settings-group .sg{background:var(--bg2);border-radius:var(--radius);padding:20px;margin-bottom:14px;border:1px solid var(--border)}
+.settings-group .sg .sglabel{font-size:13px;font-weight:600;margin-bottom:4px}
+.settings-group .sg .sgdesc{font-size:11px;color:var(--fg4);margin-bottom:12px}
+.settings-group .sg .sgrow{display:flex;align-items:center;gap:12px;margin-bottom:8px}
+.settings-group .sg input[type=text]{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:8px 14px;color:var(--fg);font-size:13px;outline:none}
+.settings-group .sg input[type=text]:focus{border-color:var(--accent)}
+.settings-group .sg .btn{padding:7px 18px;border-radius:14px;border:1px solid var(--border);background:var(--surface);color:var(--fg3);font-size:12px;transition:var(--transition)}
+.settings-group .sg .btn:hover{background:var(--accent);color:#fff;border-color:var(--accent)}
+.settings-group .sg .toggle{display:flex;align-items:center;gap:10px;cursor:pointer}
+.settings-group .sg .toggle .track{width:36px;height:20px;border-radius:10px;background:var(--border);position:relative;transition:var(--transition)}
+.settings-group .sg .toggle .track .dot{position:absolute;top:2px;left:2px;width:16px;height:16px;border-radius:50%;background:var(--fg3);transition:var(--transition)}
+.settings-group .sg .toggle.on .track{background:var(--accent)}
+.settings-group .sg .toggle.on .track .dot{left:18px;background:#fff}
+
+/* ===== 空状态 / 加载 / 错误 ===== */
+.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 20px;color:var(--fg4)}
+.empty-state .icon{font-size:48px;margin-bottom:16px;opacity:.4}
+.empty-state .msg{font-size:15px;margin-bottom:6px}
+.empty-state .sub{font-size:12px;color:var(--fg4)}
+
+.loading-state{display:flex;align-items:center;justify-content:center;padding:60px;gap:12px;color:var(--fg4);font-size:13px}
+.loading-state .spinner{width:20px;height:20px;border:2px solid var(--border);border-top-color:var(--accent2);border-radius:50%;animation:spin .8s linear infinite}
+@keyframes spin{to{transform:rotate(360deg)}}
+
+.error-state{display:flex;flex-direction:column;align-items:center;padding:60px;color:var(--fg4)}
+.error-state .icon{font-size:36px;margin-bottom:12px}
+.error-state .msg{font-size:14px;color:var(--rose);margin-bottom:4px}
+.error-state .sub{font-size:12px}
+.error-state .retry{margin-top:16px;padding:8px 24px;border-radius:16px;border:1px solid var(--accent);background:transparent;color:var(--accent2);font-size:13px;transition:var(--transition)}
+.error-state .retry:hover{background:var(--accent);color:#fff}
+
+/* ===== 弹窗 ===== */
+.modal{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:200;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .25s}
+.modal.open{opacity:1;pointer-events:all}
+.modal .modal-box{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:28px;min-width:400px;max-width:560px;box-shadow:var(--shadow)}
+.modal .modal-box h2{font-family:Georgia,serif;font-size:18px;color:var(--accent2);margin-bottom:16px}
+.modal .modal-box .modal-body{font-size:13px;color:var(--fg3);margin-bottom:20px;line-height:1.6}
+.modal .modal-box .modal-actions{display:flex;gap:10px;justify-content:flex-end}
+.modal .modal-box .modal-actions button{padding:8px 22px;border-radius:16px;font-size:13px}
+.modal .modal-box .modal-actions .secondary{background:var(--surface);border:1px solid var(--border);color:var(--fg3)}
+.modal .modal-box .modal-actions .secondary:hover{background:var(--border)}
+.modal .modal-box .modal-actions .primary{background:var(--accent);border:none;color:#fff}
+.modal .modal-box .modal-actions .primary:hover{background:var(--accent3)}
+.modal .modal-box .modal-actions .danger{background:rgba(162,74,58,.2);border:1px solid var(--accent);color:var(--rose)}
+.modal .modal-box .modal-actions .danger:hover{background:var(--accent);color:#fff}
+
+/* ===== 底部加载条 ===== */
+.load-more{text-align:center;padding:24px 0 8px}
+.load-more .btn-load{padding:10px 32px;border-radius:20px;border:1px solid var(--border);background:var(--bg2);color:var(--fg3);font-size:13px;transition:var(--transition)}
+.load-more .btn-load:hover{background:var(--accent);color:#fff;border-color:var(--accent)}
+</style>
+</head>
+<body>
+
+<!-- 右键菜单 -->
+<div class="ctx" id="ctxMenu">
+  <div class="ctx-item">▶ 播放</div>
+  <div class="ctx-item">📂 打开文件位置</div>
+  <div class="ctx-item">✏️ 编辑影片</div>
+  <div class="ctx-item" style="border-top:1px solid var(--border);margin-top:4px;padding-top:8px">♥ 收藏</div>
+  <div class="ctx-item danger" style="margin-top:2px">🗑️ 删除</div>
+</div>
+
+<div class="app">
+
+<!-- ===== 侧边栏 ===== -->
+<nav class="sidebar">
+  <div class="logo">🎞<span>CINEMA</span></div>
+
+  <div class="grp">浏览</div>
+  <a class="nav-item active" data-view="movieList" href="#"><span class="ico">📽️</span>全部影片 <span class="badge">1,304</span></a>
+  <a class="nav-item" data-view="movieList?cat=av" href="#"><span class="ico">🔞</span>AV <span class="badge">892</span></a>
+  <a class="nav-item" data-view="movieList?cat=anime" href="#"><span class="ico">🎨</span>动漫 <span class="badge">156</span></a>
+  <a class="nav-item" data-view="movieList?cat=euro" href="#"><span class="ico">🌍</span>欧美 <span class="badge">134</span></a>
+  <a class="nav-item" data-view="movieList?cat=cn" href="#"><span class="ico">🇨🇳</span>国产 <span class="badge">122</span></a>
+
+  <div class="sep"></div>
