+  --bg: #1a1513;
+  --bg2: #1f1a17;
+  --bg3: #0f0c0b;
+  --surface: #25201d;
+  --border: #2a2320;
+  --fg: #f0ebe7;
+  --fg2: #cfa899;
+  --fg3: #8a7a72;
+  --fg4: #5a4d45;
