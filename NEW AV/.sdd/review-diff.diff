+.loading-state span { color: var(--fg3); font-size: 14px; }
+.error-state .icon, .empty-state .icon { font-size: 48px; }
+.error-state .msg, .empty-state .msg { color: var(--fg3); font-size: 15px; }
+.empty-state .sub { color: var(--fg4); font-size: 12px; }
+.retry {
